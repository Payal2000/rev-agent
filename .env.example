# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Database (Supabase or local Docker) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://revagent:revagent@localhost:5432/revagent
# For Supabase: postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres
# Readonly user for Query Agent safe execution
READONLY_DATABASE_URL=postgresql+asyncpg://revagent_readonly:readonly_pass@localhost:5432/revagent

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=revagent-production

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C...    # #revenue-ops channel ID
SENDGRID_API_KEY=SG....
ALERT_EMAIL=ops@yourcompany.com

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-signing-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://revagent.vercel.app
ENVIRONMENT=development   # development | production

# ── Demo Mode ─────────────────────────────────────────────────────────────────
DEMO_MODE=false           # set true to use seed data instead of Stripe
